  <ButtonText>k__BackingField: "Je compte sur toi pour veiller sur elle dans ce cas,
    tu as l\u2019air d\u2019\xEAtre proche d\u2019elle"
  <NpcText>k__BackingField:
  - <Npc>k__BackingField: {fileID: 11400000, guid: 083d3e52eef7ee84985a8c9ab3c0d95f, type: 2}
