  <ButtonText>k__BackingField: 'Je vais aller lui parler pour lui faire comprendre
    que ce ne sont pas des choses qui se disent

'
  <NpcText>k__BackingField:
  - <Npc>k__BackingField: {fileID: 11400000, guid: 083d3e52eef7ee84985a8c9ab3c0d95f, type: 2}
