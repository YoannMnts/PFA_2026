  m_Name: 18_F3
  m_EditorClassIdentifier: Naussilus.Core::Naussilus.Core.VisualNovels.EventDatas.DialogueDatas.Answers.FinalAnswerData
  <ButtonText>k__BackingField: "La prochaine fois qu\u2019il fait \xE7a, fait lui
    regretter ses paroles"
  <NpcText>k__BackingField:
  - <Npc>k__BackingField: {fileID: 11400000, guid: d57cec67bb2a1a945ada3b66d3cb9bf5, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: f0358eca1d351f540a61dc689202b2b8, type: 2}
    <Text>k__BackingField:
    - "Ha ! Il faut pas me le dire deux fois \xE7a !"
    - "Je vous jure qu\u2019il va s\u2019en souvenir s' il ose recommencer !"
  <Effects>k__BackingField:
  - <IsEnumeration>k__BackingField: 0
    <CurrentNpcTarget>k__BackingField:
      rid: -2
    <Conditions>k__BackingField: []
    <Consequences>k__BackingField:
    - <IsGameLost>k__BackingField: 1
      <ConsequenceSide>k__BackingField:
        <IsCurrentNpc>k__BackingField: 0
        <Subject>k__BackingField:
