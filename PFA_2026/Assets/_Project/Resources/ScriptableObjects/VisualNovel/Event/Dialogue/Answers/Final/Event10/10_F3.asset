    <Text>k__BackingField:
    - "Ah ! J\u2019essaierais de ne pas vous d\xE9cevoir\u2026"
  - <Npc>k__BackingField: {fileID: 0}
    <Expression>k__BackingField: {fileID: 11400000, guid: dcd063c74af125544a8449f130643bac, type: 2}
