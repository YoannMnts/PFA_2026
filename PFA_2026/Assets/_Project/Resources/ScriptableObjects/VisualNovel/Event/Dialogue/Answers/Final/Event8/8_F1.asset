  m_EditorClassIdentifier: Naussilus.Core::Naussilus.Core.VisualNovels.EventDatas.DialogueDatas.Answers.FinalAnswerData
  <ButtonText>k__BackingField: "La prochaine fois que \xE7a arrive, tu dois trouver
    une bonne r\xE9plique \xE0 lui renvoyer en pleine face"
  <NpcText>k__BackingField:
  - <Npc>k__BackingField: {fileID: 11400000, guid: 083d3e52eef7ee84985a8c9ab3c0d95f, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: 3973df86522e4b743879172e3518e737, type: 2}
    <Text>k__BackingField:
    - "Mais comment ? Je n\u2019ai pas cette r\xE9partie!"
  - <Npc>k__BackingField: {fileID: 11400000, guid: 083d3e52eef7ee84985a8c9ab3c0d95f, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: f0358eca1d351f540a61dc689202b2b8, type: 2}
    <Text>k__BackingField:
    - "Je vais encore plus me mettre la honte\u2026"
