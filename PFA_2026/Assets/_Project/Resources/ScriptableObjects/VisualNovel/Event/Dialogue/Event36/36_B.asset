  m_EditorClassIdentifier: Naussilus.Core::Naussilus.Core.VisualNovels.EventDatas.DialogueDatas.DialogueData
  <Lines>k__BackingField:
  - <Npc>k__BackingField: {fileID: 11400000, guid: c468415a02cbf74438a48816b0fe1fa6, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: 368af27e801a8f643a3763179d93db07, type: 2}
    <Text>k__BackingField:
    - "Je cherchais une station de radio interressante, quand je suis tomb\xE9e sur
      la fr\xE9quence d\u2019une \xE9mission joliement nomm\xE9 \u201CUne folle \xE0
      bord\u201D."
    - " J\u2019ai reconnu la voix d\u2019Herlock qui s\u2019amusait \xE0 inventer
      des choses sur moi ! "
  - <Npc>k__BackingField: {fileID: 11400000, guid: c468415a02cbf74438a48816b0fe1fa6, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: f0358eca1d351f540a61dc689202b2b8, type: 2}
    <Text>k__BackingField:
    - "Le monde entier peut entendre cette \xE9mission stupide, vous vous rendez
      compte ?\r\n"
