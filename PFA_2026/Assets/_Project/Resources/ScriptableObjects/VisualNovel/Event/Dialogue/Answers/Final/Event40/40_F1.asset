  m_EditorClassIdentifier: Naussilus.Core::Naussilus.Core.VisualNovels.EventDatas.DialogueDatas.Answers.FinalAnswerData
  <ButtonText>k__BackingField: "Tant pis pour le client, on ne peux pas aller plus
    vite que \xE7a\r\n"
  <NpcText>k__BackingField:
  - <Npc>k__BackingField: {fileID: 11400000, guid: c468415a02cbf74438a48816b0fe1fa6, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: f0358eca1d351f540a61dc689202b2b8, type: 2}
    <Text>k__BackingField:
    - "Mais l\u2019argent ! Je suis d\xE9\xE7ue de vous, je pensais que vous auriez
      plus le sens des affaires que \xE7a."
  - <Npc>k__BackingField: {fileID: 11400000, guid: c468415a02cbf74438a48816b0fe1fa6, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: 3973df86522e4b743879172e3518e737, type: 2}
    <Text>k__BackingField:
    - "Je vais dire \xE0 l\u2019\xE9quipage qu\u2019ils peuvent d\xE9j\xE0 dire adieu
      \xE0 leur prime\u2026\r\n"
  <Effects>k__BackingField:
