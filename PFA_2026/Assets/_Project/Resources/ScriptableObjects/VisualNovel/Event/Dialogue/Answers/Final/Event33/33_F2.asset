  <ButtonText>k__BackingField: "Je n\u2019arrive pas \xE0 croire que tu nous ai menti
    pendant tout ce temps"
  <NpcText>k__BackingField:
  - <Npc>k__BackingField: {fileID: 11400000, guid: c468415a02cbf74438a48816b0fe1fa6, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: 3d35d0e1530830e42b12a5e80d0329dc, type: 2}
    <Text>k__BackingField:
    - "Mais\u2026"
  - <Npc>k__BackingField: {fileID: 11400000, guid: c468415a02cbf74438a48816b0fe1fa6, type: 2}
    <Expression>k__BackingField: {fileID: 11400000, guid: 368af27e801a8f643a3763179d93db07, type: 2}
    <Text>k__BackingField:
    - "Non ! Vous dites n\u2019importe quoi ! Je suis offusqu\xE9e de ces accusations."
    - "Si vous ne me voulez pas sur ce navire, je devrais peut \xEAtre m\u2019en
      aller finalement \r\n"
  <Effects>k__BackingField:
  - <IsEnumeration>k__BackingField: 0
    <CurrentNpcTarget>k__BackingField:
      rid: -2
